{
    "name": "friska-compass",
    "version": "1.0.0",
    "description": "Beautiful desktop GUI for FriskaDB",
    "main": "electron/main.js",
    "homepage": "./",
    "scripts": {
        "start": "concurrently \"npm run dev:react\" \"wait-on http://localhost:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 electron .\"",
        "dev:react": "react-scripts start",
        "build:react": "react-scripts build",
        "build": "npm run build:react && electron-builder",
        "dist": "npm run build:react && electron-builder",
        "electron": "electron ."
    },
    "keywords": [
        "friskadb",
        "database",
        "gui"
    ],
    "author": "FriskaDB Team",
    "license": "MIT",
    "dependencies": {
        "@radix-ui/react-dialog": "^1.0.5",
        "@radix-ui/react-dropdown-menu": "^2.0.6",
        "@radix-ui/react-scroll-area": "^1.0.5",
        "@radix-ui/react-select": "^2.0.0",
        "@radix-ui/react-separator": "^1.0.3",
        "@radix-ui/react-tabs": "^1.0.4",
        "@radix-ui/react-tooltip": "^1.0.7",
        "lucide-react": "^0.263.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "concurrently": "^8.2.0",
        "cross-env": "^10.1.0",
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1",
        "react-scripts": "5.0.1",
        "wait-on": "^7.2.0"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "build": {
        "extends": null,
        "appId": "com.friskadb.compass",
        "productName": "Friska Compass",
        "asar": true,
        "files": [
            "package.json",
            "electron/**/*",
            "build/**/*",
            "!node_modules/**/*"
        ],
        "asarUnpack": [
            "node_modules/**/*"
        ],
        "extraResources": [
            {
                "from": "../bin/friskadb-server.exe",
                "to": "bin/friskadb-server.exe"
            }
        ],
        "directories": {
            "app": ".",
            "buildResources": "public",
            "output": "dist"
        },
        "win": {
            "target": "nsis",
            "icon": "public/logo.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        }
    }
}